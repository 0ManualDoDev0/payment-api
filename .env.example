# ─── Application ────────────────────────────────────────────────
PORT=3000

# ─── Database (PostgreSQL) ───────────────────────────────────────
DATABASE_URL="postgresql://payment_user:payment_pass@localhost:5432/payment_db?schema=public"
POSTGRES_USER=payment_user
POSTGRES_PASSWORD=payment_pass
POSTGRES_DB=payment_db

# ─── Cache (Redis / BullMQ) ──────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_pass

# ─── Mercado Pago ────────────────────────────────────────────────
# Obtenha em https://www.mercadopago.com.br/developers
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx
MP_PUBLIC_KEY=APP_USR-xxxxxxxxxxxxxxxxxxxx
MP_WEBHOOK_SECRET=your_webhook_secret_here

# ─── Bull Board Dashboard ────────────────────────────────────────
BULL_BOARD_USER=admin
BULL_BOARD_PASS=change_me_in_production
